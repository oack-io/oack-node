{
  "name": "oack-node",
  "version": "0.1.0",
  "description": "Official Node.js client for the Oack monitoring API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "oack",
    "monitoring",
    "uptime",
    "api",
    "client",
    "status-page"
  ],
  "author": "Oack",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/oackio/oack-node.git"
  },
  "homepage": "https://oack.io",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
